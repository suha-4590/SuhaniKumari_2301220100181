//Q1: Fibonacci Number
class Solution {
    public int fib(int n) {
        
        if (n == 0) {
            return 0;
        }

        if (n == 1) {
            return 1;
        }

        // Recursive relation
        return fib(n - 1) + fib(n - 2);
    }
}

